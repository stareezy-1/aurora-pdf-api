# Server
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
CORS_ORIGIN=*

# File uploads
MAX_FILE_SIZE=52428800

# Compression defaults
COMPRESSION_JPEG_QUALITY=85
COMPRESSION_DPI=150

# API base URL (used in Swagger docs)
API_URL=https://example.com

# Swagger
SWAGGER_ENABLED=true

# Rate limiting
RATE_LIMIT_WINDOW=60000
RATE_LIMIT_MAX=100
